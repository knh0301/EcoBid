PORT=3000
NODE_ENV=development
DB_PATH=./database.sqlite

JWT_SECRET=change-me-access-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Admin accounts for mission review
# Separate multiple emails with commas.
ADMIN_EMAILS=admin1@inha.edu,manager@example.com

# Password reset code settings
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_RETURN_CODE=false

# SMTP email sending for password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="EcoBid" <noreply@ecobid.com>

# AI product draft generation
AI_PRODUCT_DRAFT_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_PRODUCT_DRAFT_MODEL=gemini-2.5-flash-lite
GEMINI_PRODUCT_DRAFT_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-lite-latest

# AI mission photo verification
AI_MISSION_AUTO_APPROVE_CONFIDENCE=0.85
GEMINI_MISSION_VERIFICATION_MODEL=gemini-2.5-flash-lite
GEMINI_MISSION_VERIFICATION_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-lite-latest

# Optional OpenAI product draft generation
OPENAI_API_KEY=your_openai_api_key
OPENAI_PRODUCT_DRAFT_MODEL=gpt-5.4-mini
