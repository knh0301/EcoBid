# ================================
# EcoBid Local API Config Example
# ================================
# 이 파일은 로컬 테스트용 설정 예시 파일입니다.
# 팀원들은 이 파일을 복사하여 env/local.env 파일을 만들어 사용합니다.

# 1. Web 브라우저에서 프론트 실행할 때
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# 2. Android Emulator에서 로컬 백엔드에 접속할 때
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api

# 3. 실제 폰 Expo Go에서 내 PC 백엔드에 접속할 때
# EXPO_PUBLIC_API_BASE_URL=http://<YOUR_PC_IP>:3000/api

# Google 로그인 OAuth 클라이언트 ID
# Android/iOS에서 테스트할 때는 각 플랫폼용 OAuth 클라이언트 ID가 필요합니다.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
